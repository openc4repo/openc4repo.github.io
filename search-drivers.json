---
---
{% assign articles = site.pages | where_exp: "item" , "item.path contains 'drivers/' " | sort:"title" %}

[
  {% for item in articles %}
    {% if item.path contains 'example' or item.path contains 'index' %}
    {% else %}
    {

      "title"    : "{{ item.title | escape }}",
      "url"      : "{{ site.baseurl }}{{ item.url }}",
      "description" : "{{item.description | escape }}",
      "tags"     : "{{ item.tags | join: ', ' }}",
      "icon"     : "{{ item.icon }}",
      "name" : "{{item.path | remove_first: '.md' | escape }}"

    }
    {% unless forloop.last %},{% endunless %}
    {% endif %}
  {% endfor %}
]
